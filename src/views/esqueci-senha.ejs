<%- include('partials/head') %>
<div class="container-estreito">
  <div class="card">
    <h1>Recuperar senha</h1>
    <p class="muted">Informe seu e-mail. Se houver uma conta, enviaremos um <strong>código de 6 dígitos</strong> para você redefinir a senha.</p>
    <div class="aviso-box" style="margin-bottom:14px">📩 O e-mail pode cair no <strong>spam / lixo eletrônico</strong> — confira lá também.</div>
    <form action="/esqueci-senha" method="post" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label for="email">E-mail</label>
      <input id="email" name="email" type="email" required value="<%= valores.email || '' %>">
      <% if (erros.email) { %><p class="erro-campo"><%= erros.email %></p><% } %>
      <div class="acoes">
        <button type="submit" class="btn">Enviar link</button>
        <a href="/login" class="btn secundario">Voltar</a>
      </div>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
