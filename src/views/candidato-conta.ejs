<%- include('partials/head') %>
<%
  var v = valores || {};
  var temValores = Object.keys(v).length > 0;
  var end = (candidato.endereco) || {};
  function val(campo, base){ return v[campo] !== undefined ? v[campo] : (base || ''); }
  var checkedDef = temValores ? (v.temDeficiencia === 'on') : candidato.temDeficiencia;
%>
<h1>Minha conta</h1>

<% if (!candidato.emailVerificado) { %>
  <div class="flash flash-aviso" role="alert">
    Seu e-mail ainda não foi confirmado. Você precisa confirmá-lo para se inscrever.
    <form action="/reenviar-verificacao" method="post" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn pequeno" type="submit">Reenviar link de confirmação</button>
    </form>
  </div>
<% } %>

<div class="card">
  <h2>Dados cadastrais</h2>
  <form action="/minha-conta" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <dl class="dados"><dt>CPF</dt><dd><%= fmt.formatarCpf(candidato.cpf) %></dd><dt>E-mail</dt><dd><%= candidato.email %> <%= candidato.emailVerificado ? '✅' : '⏳' %></dd></dl>

    <label for="nomeCompleto">Nome completo</label>
    <input id="nomeCompleto" name="nomeCompleto" required value="<%= val('nomeCompleto', candidato.nomeCompleto) %>">
    <% if (erros.nomeCompleto) { %><p class="erro-campo"><%= erros.nomeCompleto %></p><% } %>

    <label for="telefone">Telefone <span class="opcional">(opcional)</span></label>
    <input id="telefone" name="telefone" value="<%= val('telefone', candidato.telefone) %>">

    <fieldset>
      <legend>Endereço <span class="opcional">(opcional)</span></legend>
      <div class="grid cols-2">
        <div><label for="endereco_cep">CEP</label><input id="endereco_cep" name="endereco_cep" value="<%= val('endereco_cep', end.cep) %>"></div>
        <div><label for="endereco_uf">UF</label><input id="endereco_uf" name="endereco_uf" maxlength="2" value="<%= val('endereco_uf', end.uf) %>"></div>
      </div>
      <label for="endereco_logradouro">Logradouro</label>
      <input id="endereco_logradouro" name="endereco_logradouro" value="<%= val('endereco_logradouro', end.logradouro) %>">
      <div class="grid cols-2">
        <div><label for="endereco_numero">Número</label><input id="endereco_numero" name="endereco_numero" value="<%= val('endereco_numero', end.numero) %>"></div>
        <div><label for="endereco_complemento">Complemento</label><input id="endereco_complemento" name="endereco_complemento" value="<%= val('endereco_complemento', end.complemento) %>"></div>
      </div>
      <div class="grid cols-2">
        <div><label for="endereco_bairro">Bairro</label><input id="endereco_bairro" name="endereco_bairro" value="<%= val('endereco_bairro', end.bairro) %>"></div>
        <div><label for="endereco_cidade">Cidade</label><input id="endereco_cidade" name="endereco_cidade" value="<%= val('endereco_cidade', end.cidade) %>"></div>
      </div>
    </fieldset>

    <fieldset>
      <legend>Pessoa com deficiência</legend>
      <div class="check-linha">
        <input type="checkbox" id="temDeficiencia" name="temDeficiencia" value="on" <%= checkedDef ? 'checked' : '' %>>
        <label for="temDeficiencia">Declaro ser pessoa com deficiência</label>
      </div>
      <div id="bloco-deficiencia" data-toggle-by="temDeficiencia">
        <label for="descricaoDeficiencia">Descrição <span class="opcional">(opcional)</span></label>
        <textarea id="descricaoDeficiencia" name="descricaoDeficiencia" rows="3"><%= val('descricaoDeficiencia', candidato.descricaoDeficiencia) %></textarea>
      </div>
    </fieldset>

    <div class="acoes"><button class="btn" type="submit">Salvar dados</button></div>
  </form>
</div>

<div class="card">
  <h2>Alterar senha</h2>
  <form action="/minha-conta/senha" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="senhaAtual">Senha atual</label>
    <input id="senhaAtual" name="senhaAtual" type="password" required>
    <% if (erros.senhaAtual) { %><p class="erro-campo"><%= erros.senhaAtual %></p><% } %>
    <label for="novaSenha">Nova senha</label>
    <input id="novaSenha" name="novaSenha" type="password" required minlength="8">
    <% if (erros.novaSenha) { %><p class="erro-campo"><%= erros.novaSenha %></p><% } %>
    <label for="confirmaSenha">Confirmar nova senha</label>
    <input id="confirmaSenha" name="confirmaSenha" type="password" required>
    <% if (erros.confirmaSenha) { %><p class="erro-campo"><%= erros.confirmaSenha %></p><% } %>
    <div class="acoes"><button class="btn secundario" type="submit">Alterar senha</button></div>
  </form>
</div>

<div class="card">
  <h2>Seus dados (LGPD)</h2>
  <p class="muted">Você pode exportar uma cópia dos seus dados ou solicitar a exclusão da conta.</p>
  <div class="acoes">
    <a class="btn secundario" href="/minha-conta/exportar">Exportar meus dados (JSON)</a>
    <form action="/minha-conta/excluir" method="post" onsubmit="return confirm('Tem certeza? Esta ação é irreversível e só é permitida se você não tiver inscrição em edital ativo.');" style="display:inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn perigo" type="submit">Excluir minha conta</button>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
