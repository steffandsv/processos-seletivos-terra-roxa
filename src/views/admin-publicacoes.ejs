<%- include('partials/head') %>
<% var v = valores || {}; %>
<p class="meta"><a href="/admin/editais/<%= edital.id %>">&larr; <%= edital.numero %></a></p>
<h1>Documentos e publicações</h1>
<p class="muted"><%= edital.numero %> — <%= edital.titulo %>. Retificações, atas, gabaritos, resultados etc. ficam aqui e aparecem para os candidatos na página do edital.</p>

<div class="card">
  <h2>Enviar documento</h2>
  <form action="/admin/editais/<%= edital.id %>/publicacoes" method="post" enctype="multipart/form-data" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="titulo">Nome do documento</label>
    <input id="titulo" name="titulo" required value="<%= v.titulo || '' %>" placeholder="Ex.: Retificação nº 1 do Edital, Ata de Homologação, Gabarito Preliminar">
    <% if (erros.titulo) { %><p class="erro-campo"><%= erros.titulo %></p><% } %>

    <label for="arquivo">Arquivo (PDF, CSV, JPG ou PNG — até 8 MB)</label>
    <input id="arquivo" name="arquivo" type="file" accept=".pdf,.csv,.jpg,.jpeg,.png" required>
    <% if (erros.arquivo) { %><p class="erro-campo"><%= erros.arquivo %></p><% } %>

    <label for="tipo">Categoria <span class="opcional">(opcional — ajuda só a organizar)</span></label>
    <select id="tipo" name="tipo" style="max-width:280px">
      <% Object.keys(fmt.ROTULO_TIPO_PUBLICACAO).forEach(function(t){ %>
        <option value="<%= t %>" <%= (v.tipo || 'outro') === t ? 'selected' : '' %>><%= t === 'outro' ? 'Documento (geral)' : fmt.ROTULO_TIPO_PUBLICACAO[t] %></option>
      <% }); %>
    </select>

    <div class="acoes"><button class="btn" type="submit">Enviar documento</button></div>
  </form>
</div>

<div class="card">
  <h2>Documentos publicados</h2>
  <% if (edital.publicacoes.length === 0) { %>
    <p class="muted">Nenhum documento publicado ainda.</p>
  <% } else { %>
    <div class="tabela-wrap">
      <table>
        <thead><tr><th>Nome</th><th>Categoria</th><th>Publicado em</th><th>Arquivo</th><th></th></tr></thead>
        <tbody>
          <% edital.publicacoes.forEach(function(p){ %>
            <tr>
              <td><%= p.titulo %></td>
              <td><% if (p.tipo && p.tipo !== 'outro') { %><span class="badge badge-info"><%= fmt.ROTULO_TIPO_PUBLICACAO[p.tipo] || p.tipo %></span><% } else { %><span class="muted">—</span><% } %></td>
              <td><%= fmt.fmtDataHora(p.publicadoEm) %></td>
              <td><a href="/publicacoes/<%= p.id %>/arquivo" target="_blank" rel="noopener">Abrir</a></td>
              <td>
                <form action="/admin/publicacoes/<%= p.id %>/excluir" method="post" onsubmit="return confirm('Excluir esta publicação?');" style="display:inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn perigo pequeno">Excluir</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
