<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"></head>
<body style="margin:0;padding:0;background:#f1f5f9;font-family:Arial,Helvetica,sans-serif;color:#1e293b;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f1f5f9;padding:24px 0;">
    <tr><td align="center">
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;background:#ffffff;border-radius:8px;overflow:hidden;border:1px solid #e2e8f0;">
        <tr><td style="background:#0e0e29;padding:20px 28px;color:#ffffff;">
          <strong style="font-size:16px;"><%= orgao.nome %> — <%= orgao.uf %></strong><br>
          <span style="font-size:13px;opacity:.85;">Sistema de Processos Seletivos</span>
        </td></tr>
        <tr><td style="padding:28px;">
          <h1 style="font-size:19px;margin:0 0 16px;color:#0e0e29;"><%= titulo %></h1>
          <% (paragrafos || []).forEach(function(p){ %>
            <p style="font-size:14px;line-height:1.6;margin:0 0 14px;"><%- p %></p>
          <% }); %>
          <% if (typeof botao !== 'undefined' && botao) { %>
            <p style="margin:24px 0;">
              <a href="<%= botao.url %>" style="background:#6b3fe0;color:#fff;text-decoration:none;padding:12px 24px;border-radius:999px;font-size:14px;font-weight:bold;display:inline-block;"><%= botao.texto %></a>
            </p>
            <p style="font-size:12px;color:#64748b;word-break:break-all;">Se o botão não funcionar, copie e cole no navegador:<br><%= botao.url %></p>
          <% } %>
        </td></tr>
        <tr><td style="padding:18px 28px;background:#f8fafc;border-top:1px solid #e2e8f0;font-size:11px;color:#64748b;line-height:1.5;">
          Esta é uma mensagem automática — não responda a este e-mail.<br>
          Em caso de dúvidas sobre tratamento de dados, contate o Encarregado (DPO)<% if (orgao.dpoContato) { %>: <%= orgao.dpoContato %><% } %>.
        </td></tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
