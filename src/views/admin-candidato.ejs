<%- include('partials/head') %>
<%
  var v = valores || {};
  var temValores = Object.keys(v).length > 0;
  var end = candidato.endereco || {};
  function val(campo, base){ return v[campo] !== undefined ? v[campo] : (base || ''); }
  var checkedDef = temValores ? (v.temDeficiencia === 'on') : candidato.temDeficiencia;
  var checkedVerif = temValores ? (v.emailVerificado === 'on') : candidato.emailVerificado;
%>
<p class="meta"><a href="/admin/candidatos">&larr; Candidatos</a></p>
<h1><%= candidato.nomeCompleto %></h1>
<p>
  <span class="badge <%= candidato.emailVerificado ? 'badge-ok' : 'badge-neutro' %>"><%= candidato.emailVerificado ? 'Conta confirmada' : 'Conta não confirmada' %></span>
  · CPF <%= fmt.formatarCpf(candidato.cpf) %> · cadastro <%= fmt.fmtData(candidato.criadoEm) %>
</p>

<div class="card">
  <h2>Dados cadastrais</h2>
  <form action="/admin/candidatos/<%= candidato.id %>" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="nomeCompleto">Nome completo</label>
    <input id="nomeCompleto" name="nomeCompleto" required value="<%= val('nomeCompleto', candidato.nomeCompleto) %>" <%= erros.nomeCompleto ? 'aria-invalid="true"' : '' %>>
    <% if (erros.nomeCompleto) { %><p class="erro-campo"><%= erros.nomeCompleto %></p><% } %>

    <label for="email">E-mail</label>
    <input id="email" name="email" type="email" required value="<%= val('email', candidato.email) %>" <%= erros.email ? 'aria-invalid="true"' : '' %>>
    <% if (erros.email) { %><p class="erro-campo"><%= erros.email %></p><% } %>

    <label for="telefone">Telefone <span class="opcional">(opcional)</span></label>
    <input id="telefone" name="telefone" value="<%= val('telefone', candidato.telefone) %>">

    <fieldset>
      <legend>Endereço <span class="opcional">(opcional)</span></legend>
      <div class="grid cols-2">
        <div><label for="endereco_cep">CEP</label><input id="endereco_cep" name="endereco_cep" value="<%= val('endereco_cep', end.cep) %>"></div>
        <div><label for="endereco_uf">UF</label><input id="endereco_uf" name="endereco_uf" maxlength="2" value="<%= val('endereco_uf', end.uf) %>"></div>
      </div>
      <label for="endereco_logradouro">Logradouro</label>
      <input id="endereco_logradouro" name="endereco_logradouro" value="<%= val('endereco_logradouro', end.logradouro) %>">
      <div class="grid cols-2">
        <div><label for="endereco_numero">Número</label><input id="endereco_numero" name="endereco_numero" value="<%= val('endereco_numero', end.numero) %>"></div>
        <div><label for="endereco_bairro">Bairro</label><input id="endereco_bairro" name="endereco_bairro" value="<%= val('endereco_bairro', end.bairro) %>"></div>
      </div>
      <label for="endereco_cidade">Cidade</label>
      <input id="endereco_cidade" name="endereco_cidade" value="<%= val('endereco_cidade', end.cidade) %>">
    </fieldset>

    <fieldset>
      <legend>Pessoa com deficiência</legend>
      <div class="check-linha"><input type="checkbox" id="temDeficiencia" name="temDeficiencia" value="on" <%= checkedDef ? 'checked' : '' %>><label for="temDeficiencia">Declarada</label></div>
      <label for="descricaoDeficiencia">Descrição <span class="opcional">(opcional)</span></label>
      <textarea id="descricaoDeficiencia" name="descricaoDeficiencia" rows="2"><%= val('descricaoDeficiencia', candidato.descricaoDeficiencia) %></textarea>
    </fieldset>

    <div class="check-linha"><input type="checkbox" id="emailVerificado" name="emailVerificado" value="on" <%= checkedVerif ? 'checked' : '' %>><label for="emailVerificado"><strong>Conta confirmada</strong> (marque para confirmar manualmente, mesmo sem o candidato clicar no link)</label></div>

    <div class="acoes"><button class="btn" type="submit">Salvar cadastro</button></div>
  </form>
</div>

<div class="card">
  <h2>Resetar senha</h2>
  <p class="muted">Define uma nova senha para o candidato. Informe a ele depois (de preferência por um canal seguro).</p>
  <form action="/admin/candidatos/<%= candidato.id %>/senha" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label for="novaSenha">Nova senha</label>
    <input id="novaSenha" name="novaSenha" type="text" required minlength="8" autocomplete="off" placeholder="mín. 8 caracteres, com letras e números">
    <% if (erros.novaSenha) { %><p class="erro-campo"><%= erros.novaSenha %></p><% } %>
    <label for="confirmaSenha">Confirmar nova senha</label>
    <input id="confirmaSenha" name="confirmaSenha" type="text" required autocomplete="off">
    <% if (erros.confirmaSenha) { %><p class="erro-campo"><%= erros.confirmaSenha %></p><% } %>
    <div class="acoes"><button class="btn secundario" type="submit">Redefinir senha</button></div>
  </form>
</div>

<div class="card">
  <h2>Inscrições</h2>
  <% if (candidato.inscricoes.length === 0) { %>
    <p class="muted">Nenhuma inscrição.</p>
  <% } else { %>
    <ul>
      <% candidato.inscricoes.forEach(function(i){ %>
        <li><a href="/admin/inscricoes/<%= i.id %>">Nº <%= i.numeroInscricao %></a> — <%= i.edital.numero %> · <%= i.cargo.nome %>
          <span class="badge <%= fmt.CLASSE_STATUS_INSCRICAO[i.status] %>"><%= fmt.ROTULO_STATUS_INSCRICAO[i.status] %></span></li>
      <% }); %>
    </ul>
  <% } %>
</div>

<div class="card" style="border-color:#fca5a5">
  <h2>Excluir cadastro</h2>
  <p class="muted">Remove o candidato e todos os seus dados/arquivos. Ação irreversível.</p>
  <form action="/admin/candidatos/<%= candidato.id %>/excluir" method="post" onsubmit="return confirm('Excluir definitivamente o cadastro de <%= candidato.nomeCompleto.replace(/'/g, '') %>? Esta ação é irreversível.');">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button class="btn perigo" type="submit">Excluir cadastro</button>
  </form>
</div>
<%- include('partials/footer') %>
