<%- include('partials/head') %>
<div class="container-estreito">
  <h1>Criar conta</h1>
  <p class="muted">Cadastro gratuito. O documento com foto só será solicitado no momento da inscrição.</p>
  <% if (erros._) { %><div class="flash flash-erro" role="alert"><%= erros._ %></div><% } %>

  <form action="/cadastro" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="card">
      <h2>Dados pessoais</h2>
      <label for="nomeCompleto">Nome completo</label>
      <input id="nomeCompleto" name="nomeCompleto" required value="<%= valores.nomeCompleto || '' %>" <%= erros.nomeCompleto ? 'aria-invalid="true"' : '' %>>
      <% if (erros.nomeCompleto) { %><p class="erro-campo"><%= erros.nomeCompleto %></p><% } %>

      <label for="cpf">CPF</label>
      <input id="cpf" name="cpf" inputmode="numeric" placeholder="000.000.000-00" required value="<%= valores.cpf || '' %>" <%= erros.cpf ? 'aria-invalid="true"' : '' %>>
      <% if (erros.cpf) { %><p class="erro-campo"><%= erros.cpf %></p><% } %>

      <label for="email">E-mail</label>
      <input id="email" name="email" type="email" required value="<%= valores.email || '' %>" <%= erros.email ? 'aria-invalid="true"' : '' %>>
      <p class="dica">Você precisará confirmar este e-mail antes de se inscrever.</p>
      <% if (erros.email) { %><p class="erro-campo"><%= erros.email %></p><% } %>

      <label for="telefone">Telefone <span class="opcional">(opcional)</span></label>
      <input id="telefone" name="telefone" value="<%= valores.telefone || '' %>">
    </div>

    <fieldset>
      <legend>Endereço <span class="opcional">(opcional)</span></legend>
      <div class="grid cols-2">
        <div><label for="endereco_cep">CEP</label><input id="endereco_cep" name="endereco_cep" value="<%= valores.endereco_cep || '' %>"></div>
        <div><label for="endereco_uf">UF</label><input id="endereco_uf" name="endereco_uf" maxlength="2" value="<%= valores.endereco_uf || '' %>"></div>
      </div>
      <label for="endereco_logradouro">Logradouro</label>
      <input id="endereco_logradouro" name="endereco_logradouro" value="<%= valores.endereco_logradouro || '' %>">
      <div class="grid cols-2">
        <div><label for="endereco_numero">Número</label><input id="endereco_numero" name="endereco_numero" value="<%= valores.endereco_numero || '' %>"></div>
        <div><label for="endereco_complemento">Complemento</label><input id="endereco_complemento" name="endereco_complemento" value="<%= valores.endereco_complemento || '' %>"></div>
      </div>
      <div class="grid cols-2">
        <div><label for="endereco_bairro">Bairro</label><input id="endereco_bairro" name="endereco_bairro" value="<%= valores.endereco_bairro || '' %>"></div>
        <div><label for="endereco_cidade">Cidade</label><input id="endereco_cidade" name="endereco_cidade" value="<%= valores.endereco_cidade || '' %>"></div>
      </div>
    </fieldset>

    <fieldset>
      <legend>Pessoa com deficiência <span class="opcional">(opcional)</span></legend>
      <p class="dica">Informação usada exclusivamente para eventual atendimento especial na prova. Nunca é divulgada em listas públicas.</p>
      <div class="check-linha">
        <input type="checkbox" id="temDeficiencia" name="temDeficiencia" value="on" <%= valores.temDeficiencia === 'on' ? 'checked' : '' %>>
        <label for="temDeficiencia">Declaro ser pessoa com deficiência</label>
      </div>
      <div id="bloco-deficiencia" data-toggle-by="temDeficiencia">
        <label for="descricaoDeficiencia">Descrição <span class="opcional">(opcional)</span></label>
        <textarea id="descricaoDeficiencia" name="descricaoDeficiencia" rows="3"><%= valores.descricaoDeficiencia || '' %></textarea>
      </div>
    </fieldset>

    <div class="card">
      <h2>Senha</h2>
      <label for="senha">Senha</label>
      <input id="senha" name="senha" type="password" required minlength="8" <%= erros.senha ? 'aria-invalid="true"' : '' %>>
      <p class="dica">Mínimo 8 caracteres, com letras e números.</p>
      <% if (erros.senha) { %><p class="erro-campo"><%= erros.senha %></p><% } %>

      <label for="confirmaSenha">Confirmar senha</label>
      <input id="confirmaSenha" name="confirmaSenha" type="password" required <%= erros.confirmaSenha ? 'aria-invalid="true"' : '' %>>
      <% if (erros.confirmaSenha) { %><p class="erro-campo"><%= erros.confirmaSenha %></p><% } %>

      <div class="check-linha" style="margin-top:16px">
        <input type="checkbox" id="aceiteTermos" name="aceiteTermos" value="on" <%= valores.aceiteTermos === 'on' ? 'checked' : '' %>>
        <label for="aceiteTermos">Li e aceito os <a href="/termos-de-uso" target="_blank">Termos de Uso</a> e o <a href="/aviso-de-privacidade" target="_blank">Aviso de Privacidade</a>.</label>
      </div>
      <% if (erros.aceiteTermos) { %><p class="erro-campo"><%= erros.aceiteTermos %></p><% } %>
    </div>

    <div class="acoes">
      <button type="submit" class="btn">Criar conta</button>
      <a href="/login" class="btn secundario">Já tenho conta</a>
    </div>
  </form>
</div>
<%- include('partials/footer') %>
