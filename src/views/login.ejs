<%- include('partials/head') %>
<div class="container-estreito">
  <div class="card">
    <h1>Entrar</h1>
    <% if (erros._) { %><div class="flash flash-erro" role="alert"><%= erros._ %></div><% } %>
    <form action="/login" method="post" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="next" value="<%= next || '' %>">
      <label for="email">E-mail</label>
      <input id="email" name="email" type="email" required value="<%= valores.email || '' %>">
      <% if (erros.email) { %><p class="erro-campo"><%= erros.email %></p><% } %>
      <label for="senha">Senha</label>
      <input id="senha" name="senha" type="password" required>
      <% if (erros.senha) { %><p class="erro-campo"><%= erros.senha %></p><% } %>
      <div class="acoes">
        <button type="submit" class="btn">Entrar</button>
        <a href="/esqueci-senha">Esqueci minha senha</a>
      </div>
    </form>
  </div>
  <p class="muted" style="text-align:center">Não tem conta? <a href="/cadastro">Cadastre-se</a>.</p>
</div>
<%- include('partials/footer') %>
