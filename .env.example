# ----------------------------------------------------------------------------
# Sistema de Processos Seletivos — variáveis de ambiente
# Copie para .env e preencha. NUNCA versione o .env real.
# ----------------------------------------------------------------------------

# Ambiente: development | production
NODE_ENV=development

# Porta e bind do app Node
PORT=3000
HOST=0.0.0.0

# URL pública (usada em links de e-mail: verificação, reenvio, etc.)
APP_BASE_URL=http://localhost:3000

# Conexão com o PostgreSQL (role e database dedicados do sistema)
DATABASE_URL=postgresql://processos_app:SENHA@HOST:5432/processos_seletivos?schema=public

# Segredo para assinar cookies de sessão/CSRF (>= 32 chars). Gere com:
#   openssl rand -hex 32
SESSION_SECRET=troque-por-um-segredo-aleatorio-de-32-bytes

# Chave para criptografar documentos em repouso (32 bytes em hex = 64 chars). Gere com:
#   openssl rand -hex 32
DOC_ENCRYPTION_KEY=troque-por-uma-chave-hex-de-64-caracteres

# Diretório de uploads (volume Docker fora da raiz web)
UPLOAD_DIR=./data/uploads

# Cookies seguros (true em produção atrás de HTTPS/Caddy)
COOKIE_SECURE=false

# ---- SMTP (e-mail) -----------------------------------------------------------
# Se SMTP_HOST estiver vazio, o sistema usa modo de desenvolvimento:
# os e-mails são apenas registrados no log e na tabela notificacao_email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Processos Seletivos - Terra Roxa <nao-responda@terraroxa.sp.gov.br>"

# ---- Entidade (textos institucionais) ---------------------------------------
ORGAO_NOME=Prefeitura Municipal de Terra Roxa
ORGAO_UF=SP
DPO_CONTATO=encarregado@terraroxa.sp.gov.br
